{
  "name": "bosch-sdlc",
  "version": "0.1.0",
  "private": false,
  "workspaces": ["protocol", "server", "ui"],
  "engines": { "node": ">=20" },
  "bin": { "bosch-sdlc": "./server/dist/bin.js" },
  "scripts": {
    "build": "npm run build -w protocol && npm run build -w server && npm run build -w ui",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "pack": "npm run build && node scripts/pack.js",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "files": ["server/dist/**", "protocol/dist/**", "protocol/package.json", "scripts/postinstall.js"],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "express": "^4.19.0",
    "ws": "^8.17.0",
    "better-sqlite3": "^12.0.0",
    "open": "^10.1.0",
    "zod": "^4.0.0"
  },
  "bundleDependencies": true,
  "devDependencies": {
    "typescript": "^5.4.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.2.0"
  }
}
